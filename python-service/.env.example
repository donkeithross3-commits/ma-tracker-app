# Interactive Brokers Connection
IB_HOST=127.0.0.1
IB_PORT=7497
# 7497 for paper trading, 7496 for live trading

# Server Configuration
PORT=8000
HOST=0.0.0.0

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# WebSocket Relay - API key for authenticating remote IB data providers
# Generate a secure random key: openssl rand -hex 32
IB_PROVIDER_API_KEY=your-secure-api-key-here

# Polygon.io API key — primary data source for stock/options quotes
# Required for curate/monitor tabs to work without an IB agent connected
POLYGON_API_KEY=your-polygon-api-key

# Set to "false" to disable Polygon-first and always use IB relay
# POLYGON_PRIMARY=true

# Chief of Staff — DeepSeek-R1 via vLLM (RunPod)
COS_VLLM_URL=https://your-runpod-endpoint-8000.proxy.runpod.net
COS_VLLM_MODEL=/workspace/models/DeepSeek-R1-Distill-Qwen-32B
COS_ESCALATION_THRESHOLD=0.5
COS_DATA_DIR=/home/don/apps/data/cos
