# DR3 Trading Agent — Droplet Configuration
# Copy to ~/apps/ma-tracker-app/python-service/standalone_agent/config.env
# and fill in the IB_PROVIDER_KEY from the dashboard

# IB Gateway connection (running in Docker on same machine)
IB_HOST=127.0.0.1
IB_PORT=4002          # 4002=paper, 4001=live (IB Gateway ports, not TWS)
IB_MODE=paper         # paper or live
IB_CLIENT_ID=0        # Must be 0 for reqAutoOpenOrders compatibility

# WebSocket relay (localhost since agent and server are colocated)
RELAY_URL=ws://localhost:8000/ws/data-provider

# API key for relay authentication (generate from dashboard: /api/ma-options/download-agent)
IB_PROVIDER_KEY=<PLACEHOLDER — generate from dashboard>

# BMC strategy model path (py_proj on droplet)
BMC_PATH=/home/don/apps/py_proj
