# IB Gateway Credentials — NEVER commit real values to git
# Copy to ~/apps/ib-gateway.env on the droplet and fill in real values
# chmod 600 ~/apps/ib-gateway.env
#
# Variable names must match gnzsnz/ib-gateway image expectations

# IB login credentials
TWS_USERID=<your-ib-username>
TWS_PASSWORD=<your-ib-password>

# Trading mode: paper or live
IB_TRADING_MODE=paper

# VNC password for debugging (optional — leave empty to disable VNC)
VNC_SERVER_PASSWORD=
